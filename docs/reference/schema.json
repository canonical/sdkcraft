{
    "$schema":"https://json-schema.org/draft/2020-12/schema",
    "$id":"https://canonical.com/sdkcraft.yaml",
    "properties":{
        "name":{
            "type":"string"
        },
        "base":{
            "type":"string",
            "enum":[
                "ubuntu@20.04",
                "ubuntu@22.04",
                "ubuntu@24.04"
            ]
        },
        "summary":{
            "type":"string",
            "maxLength": 79
        },
        "description":{
            "type":"string"
        },
        "version":{
            "type":"string"
        },
        "license":{
            "type":"string"
        },
        "platforms":{
            "type":"object",
            "additionalProperties":{
                "type":"object"
            }
        },
        "parts":{
            "type":"object",
            "additionalProperties":{
                "type":"object",
                "properties":{
                    "plugin":{
                        "type":"string"
                    }
                },
                "required":[
                    "plugin"
                ],
                "additionalProperties":true
            }
        },
        "plugs":{
            "type":"object",
            "additionalProperties":{
                "type":"object",
                "properties":{
                    "interface":{
                        "type":"string"
                    }
                },
                "required":[
                    "interface"
                ],
                "additionalProperties":true
            }
        }
    },
    "required":[
        "name",
        "base",
        "summary",
        "description",
        "version",
        "license",
        "platforms",
        "parts"
    ]
}